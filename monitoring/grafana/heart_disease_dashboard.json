{
  "annotations": {"list": []},
  "editable": true,
  "schemaVersion": 39,
  "title": "Heart Disease API",
  "tags": ["mlops", "heart-disease"],
  "timezone": "browser",
  "refresh": "10s",
  "time": {"from": "now-30m", "to": "now"},
  "panels": [
    {
      "type": "stat",
      "title": "Total predictions",
      "id": 1,
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "targets": [{"expr": "sum(heart_disease_predictions_total)", "refId": "A"}],
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4}
    },
    {
      "type": "stat",
      "title": "Predictions per second (1m avg)",
      "id": 2,
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "targets": [{"expr": "sum(rate(heart_disease_predictions_total[1m]))", "refId": "A"}],
      "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4}
    },
    {
      "type": "timeseries",
      "title": "Predictions by class",
      "id": 3,
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "targets": [
        {"expr": "sum by (prediction) (rate(heart_disease_predictions_total[1m]))", "legendFormat": "class={{prediction}}", "refId": "A"}
      ],
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8}
    },
    {
      "type": "timeseries",
      "title": "/predict latency (p95)",
      "id": 4,
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "targets": [
        {"expr": "histogram_quantile(0.95, sum(rate(heart_disease_prediction_latency_seconds_bucket[5m])) by (le))", "legendFormat": "p95", "refId": "A"}
      ],
      "gridPos": {"x": 0, "y": 4, "w": 12, "h": 8}
    },
    {
      "type": "timeseries",
      "title": "HTTP request rate",
      "id": 5,
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "targets": [
        {"expr": "sum by (handler, status) (rate(http_requests_total[1m]))", "legendFormat": "{{handler}} {{status}}", "refId": "A"}
      ],
      "gridPos": {"x": 0, "y": 12, "w": 24, "h": 8}
    }
  ]
}
